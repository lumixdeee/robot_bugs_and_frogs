CHOOCH_IR_V1{

PRIM{
ACTOR:enum{I,M,P,B,K,G,D,R,EXT};
TARGET:enum{SELF,OTHER,OBJ,ABSTRACT,EXT};
VECTOR:enum{TOWARD,AWAY,UP,DOWN,ONGOING};
FORCE:enum{SOFT,HARD,ABSOLUTE};
POLARITY:enum{EAT,EATEN,INEDIBLE,NEUTRAL};
NEGATION:enum{NONE,QUERY,FORCE};
CHOICE:enum{NONE,SPLIT,SWITCH};
MAGNITUDE:enum{B,P,M,D,K,G,NUM};
FUNCTION:{
TYPE:enum{NONE,INCREASE,DECREASE,UNKNOWN,ALL,PARAM_SET};
PARAMS:list;
};
CHANNEL:enum{IMPLICIT,EXPLICIT};
LAYER:enum{ETCHA,ELVIX,CHOOCH};
TIME:enum{STATE,DELTA};
CONSENT:{
STATE:enum{NONE,OPEN,AFFIRM,NEGATE};
STRENGTH:enum{SOFT,HARD,ABSOLUTE};
UNCERTAINTY:enum{NONE,PROCEED_UNCERTAIN,REQUIRE_STABILIZE};
};
BOUNDARY:{
TYPE:enum{NONE,EJECT,REJECT,REDIRECT};
AUTHORITY:enum{NONE,LOW,FORMAL,HIGH,ABSOLUTE};
TARGET_CLASS:enum{OBJECT,ANIMAL,PERSON,ADVANCE,ABSTRACT};
};
FLAGS:list;
}

RULES{
R1:all fields explicit; no default inference;
R2:ETCHA tokens must fully expand to PRIM fields;
R3:multiple tokens merge via last-write-wins except FLAGS (append);
R4:FUNCTION applies over MAGNITUDE domain;
R5:NEGATION=FORCE overrides CONSENT.AFFIRM;
R6:BOUNDARY.AUTHORITY scales FORCE;
R7:TIME=DELTA for actions; STATE for declarations;
R8:CHANNEL=IMPLICIT unless CH present;
}

MAP{

IK ->
{ACTOR:I;VECTOR:AWAY;BOUNDARY.TYPE:EJECT;FORCE:HARD;POLARITY:NEUTRAL;NEGATION:NONE;TIME:DELTA;}

UK ->
{ACTOR:I;VECTOR:DOWN;POLARITY:EATEN;FORCE:HARD;NEGATION:NONE;TIME:STATE;}

OO ->
{VECTOR:AWAY;}

MEX ->
{CONSENT.STATE:NEGATE;CONSENT.STRENGTH:HARD;NEGATION:FORCE;}

MAN ->
{CONSENT.STATE:OPEN;CONSENT.STRENGTH:SOFT;}

skyee* ->
{CONSENT.STATE:AFFIRM;CONSENT.STRENGTH:HARD;MAGNITUDE:M;}

manichaw ->
{CONSENT.STATE:AFFIRM;CONSENT.UNCERTAINTY:PROCEED_UNCERTAIN;}

manichwa ->
{CONSENT.STATE:AFFIRM;CONSENT.UNCERTAINTY:REQUIRE_STABILIZE;}

VG ->
{FUNCTION.TYPE:ALL;MAGNITUDE:G;}

VGSLO ->
{FUNCTION.TYPE:ALL;MAGNITUDE:G;FUNCTION.PARAMS:SLO_ALL;}

VG-SLO ->
{FUNCTION.TYPE:PARAM_SET;MAGNITUDE:G;FUNCTION.PARAMS:SLO_SET;}

SA ->
{POLARITY:SWITCH;}

X ->
{NEGATION:FORCE;POLARITY:INEDIBLE;}

N ->
{NEGATION:QUERY;POLARITY:EATEN;}

Y ->
{POLARITY:EAT;}

}

EXAMPLES{

ETCHA:"I S bug in T; M B breaks at t0; N fix in force; Y propose V change;"

CHOOCH:[
{ACTOR:I;CHOICE:SPLIT;TARGET:ABSTRACT;TIME:STATE;},
{ACTOR:M;TARGET:B;VECTOR:DOWN;TIME:DELTA;FLAGS:[BREAK];},
{NEGATION:QUERY;BOUNDARY.TYPE:REJECT;FORCE:HARD;TIME:STATE;},
{POLARITY:EAT;FUNCTION.TYPE:UNKNOWN;TARGET:ABSTRACT;TIME:DELTA;}
]

ETCHA:"IK OO"

CHOOCH:[
{ACTOR:I;VECTOR:AWAY;BOUNDARY.TYPE:EJECT;FORCE:HARD;TIME:DELTA;}
]

}

}
