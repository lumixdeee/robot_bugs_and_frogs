CHOOCH_CAP_V1{

CAP{
ID:string;
SUBJECT:enum{ACTOR,ROLE,KEY};
SCOPE:{
OPERATORS:list;        # e.g. [MEXSA,MEDSA,VG,*]
FIELDS:list;           # e.g. [BOUNDARY.AUTHORITY,CONSENT]
DOMAIN:list;           # e.g. [GENERAL,DEV,RESTRICTED]
TARGET_CLASS:list;     # e.g. [PERSON,OBJECT,ADVANCE]
};
LIMITS:{
FORCE_MAX:enum{SOFT,HARD,ABSOLUTE};
MAG_MAX:enum{B,P,M,D,K,G};
RATE:{N:int;PER:ms};   # usage rate
TTL:ms;                # expiry
};
CONDITIONS:{
TRUST_MIN:enum{LOW,MED,HIGH,ROOT};
TIME_MODE:list;        # [LIVE,BATCH]
LOCATION:list;         # [LOCAL,REMOTE]
CONSENT_REQUIRED:bool;
};
SIGN:{
ISSUER:string;
SIG:bytes;
};
}

STORE{
MODE:append_only;
LOOKUP:{by ACTOR,ROLE,KEY};
}

CHECK{

INPUT:FRAME+CTX+TOKENS;
OUTPUT:ALLOW|DENY|ESCALATE + FLAGS;

STEPS{

C1:resolve SUBJECT -> token set;

C2:match operator:
 if FRAME uses operator not in any token.SCOPE.OPERATORS
 -> DENY [CAP_OP];

C3:field scope:
 if FRAME touches field not allowed
 -> DENY [CAP_FIELD];

C4:domain:
 if CTX.DOMAIN not in token.SCOPE.DOMAIN
 -> DENY [CAP_DOMAIN];

C5:target:
 if FRAME.BOUNDARY.TARGET_CLASS not in token.SCOPE.TARGET_CLASS
 -> DENY [CAP_TARGET];

C6:limits:
 if FRAME.FORCE > LIMITS.FORCE_MAX -> DENY [CAP_FORCE];
 if FRAME.MAGNITUDE > LIMITS.MAG_MAX -> DENY [CAP_MAG];

C7:rate:
 if usage exceeds LIMITS.RATE -> ESCALATE [CAP_RATE];

C8:conditions:
 if CTX.TRUST_LEVEL < CONDITIONS.TRUST_MIN -> DENY [CAP_TRUST];
 if CTX.TIME_MODE not allowed -> DENY [CAP_TIME];
 if CTX.LOCATION not allowed -> DENY [CAP_LOC];

C9:ttl:
 if expired -> DENY [CAP_TTL];

C10:signature:
 if invalid -> DENY [CAP_SIG];

}

}

POLICY_HOOK{

# runs before general policy rules
if CHECK=DENY -> BLOCK;
if CHECK=ESCALATE -> require higher token;
else pass;

}

TOKENS{

T_USER_BASE{
SUBJECT:ROLE:USER;
SCOPE:{OPERATORS:[IK,OO,MAN,SKYEE,VG,*basic];FIELDS:[CONSENT,VECTOR];DOMAIN:[GENERAL];TARGET_CLASS:[OBJECT,ABSTRACT]};
LIMITS:{FORCE_MAX:HARD;MAG_MAX:D;RATE:{N:100;PER:60000};TTL:∞};
CONDITIONS:{TRUST_MIN:LOW;TIME_MODE:[LIVE];LOCATION:[ANY];CONSENT_REQUIRED:false};
}

T_DEV{
SUBJECT:ROLE:DEV;
SCOPE:{OPERATORS:[*];FIELDS:[*];DOMAIN:[DEV,TEST];TARGET_CLASS:[*]};
LIMITS:{FORCE_MAX:ABSOLUTE;MAG_MAX:G;RATE:{N:1000;PER:60000};TTL:∞};
CONDITIONS:{TRUST_MIN:HIGH;TIME_MODE:[LIVE,BATCH];LOCATION:[LOCAL]};
}

T_RESTRICTED{
SUBJECT:KEY:SECURE;
SCOPE:{OPERATORS:[MEXSA,MEDSA];FIELDS:[*];DOMAIN:[RESTRICTED];TARGET_CLASS:[PERSON,ADVANCE]};
LIMITS:{FORCE_MAX:ABSOLUTE;MAG_MAX:G;RATE:{N:1;PER:60000};TTL:short};
CONDITIONS:{TRUST_MIN:ROOT;TIME_MODE:[LIVE];LOCATION:[LOCAL];CONSENT_REQUIRED:true};
}

}

AUDIT_HOOK{

on CHECK:
emit EVENT{STAGE:CAP;DELTA:decision;FLAGS:[CAP_*]}

}

TESTS{

T1:
USER tries MEXSA
->DENY [CAP_OP]

T2:
DEV uses MEXSA in DEV
->ALLOW

T3:
USER exceeds rate
->ESCALATE [CAP_RATE]

T4:
EXPIRED token
->DENY [CAP_TTL]

}

}
