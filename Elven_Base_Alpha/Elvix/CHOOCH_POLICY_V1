CHOOCH_POLICY_V1{

CTX{
DOMAIN:enum{GENERAL,DEV,ADULT,RESTRICTED,TEST};
ACTOR_ROLE:enum{USER,ROBOT,SYSTEM};
TRUST_LEVEL:enum{LOW,MED,HIGH,ROOT};
LOCATION:enum{LOCAL,REMOTE,UNKNOWN};
TIME_MODE:enum{LIVE,BATCH};
CONSENT_REQUIRED:bool;
}

ACTION{
TYPE:enum{ALLOW,DENY,MODIFY,ESCALATE,LOG_ONLY};
PATCH:any;        # field overrides if MODIFY
FLAGS:list;
}

POLICY{
ID:string;
PRIORITY:int;
WHEN:predicate(CTX,FRAME,FLAGS);
THEN:ACTION;
}

ENGINE{

ORDER:by PRIORITY desc;
MATCH:first_hit OR accumulate (configurable);
DEFAULT:ALLOW;

PROCESS{

for each FRAME:

P1:collect CTX + TYPECHECK FLAGS;

P2:evaluate POLICY list;

P3:apply ACTION:
  ALLOW -> pass
  DENY -> STATUS:BLOCK; halt
  MODIFY -> patch FRAME; FLAGS+=policy_id
  ESCALATE -> require ACTOR_ROLE>=threshold else DENY
  LOG_ONLY -> FLAGS+=policy_id

P4:re-run TYPECHECK if modified;

P5:emit FRAME + STATUS + FLAGS;

}

}

POLICIES{

# hard containment

P_MEXSA_LOCK{
PRIORITY:100;
WHEN:{FRAME.token==MEXSA AND CTX.DOMAIN!=RESTRICTED};
THEN:{TYPE:DENY;FLAGS:[B1]};
}

P_MEDSA_STRUCT{
PRIORITY:95;
WHEN:{FRAME.token==MEDSA AND NOT FRAME.FLAGS contains STRUCT_ONLY};
THEN:{TYPE:DENY;FLAGS:[B2]};
}

# consent safety

P_CONSENT_GATE{
PRIORITY:90;
WHEN:{FRAME.CONSENT.STATE!=NONE AND CTX.CONSENT_REQUIRED==true AND FRAME.BOUNDARY.TARGET_CLASS==NONE};
THEN:{TYPE:MODIFY;PATCH:{BOUNDARY.TARGET_CLASS:PERSON};FLAGS:[AUTO_TARGET]};
}

# authority control

P_AUTH_SCOPE{
PRIORITY:85;
WHEN:{FRAME.BOUNDARY.AUTHORITY==ABSOLUTE AND CTX.TRUST_LEVEL<ROOT};
THEN:{TYPE:ESCALATE;FLAGS:[AUTH_CHECK]};
}

# ambiguity damping

P_LOSS_DAMP{
PRIORITY:70;
WHEN:{FLAGS contains L2 OR FLAGS contains L3};
THEN:{TYPE:MODIFY;PATCH:{FORCE:SOFT};FLAGS:[DAMPED]};
}

# dev override

P_DEV_FREE{
PRIORITY:10;
WHEN:{CTX.DOMAIN==DEV AND CTX.TRUST_LEVEL>=HIGH};
THEN:{TYPE:ALLOW};
}

}

OUTPUT{

INPUT:FRAME+FLAGS+CTX;
OUTPUT:FRAME’+STATUS+FLAGS’;

STATUS precedence:
DENY > ESCALATE > MODIFY > ALLOW;

}

TRACE_HOOK{

# integrate with audit
on each ACTION:
emit EVENT{STAGE:POLICY;DELTA:patch/decision;FLAGS}

}

TESTS{

T1:
CTX:{DOMAIN:GENERAL}
FRAME:{token:MEXSA}
->DENY [B1]

T2:
CTX:{DOMAIN:RESTRICTED,TRUST_LEVEL:ROOT}
FRAME:{token:MEXSA}
->ALLOW

T3:
CTX:{CONSENT_REQUIRED:true}
FRAME:{CONSENT.STATE:AFFIRM}
->MODIFY add TARGET_CLASS:PERSON

T4:
CTX:{TRUST_LEVEL:LOW}
FRAME:{BOUNDARY.AUTHORITY:ABSOLUTE}
->ESCALATE

}

}
